  "stage_plan": {
    "core-services": {
      "description": "实现所有 models、services、stores、fixtures、support 文件，建立完整的数据层和业务逻辑层",
      "target_paths": [
        "entry/src/main/ets/models/",
        "entry/src/main/ets/services/",
        "entry/src/main/ets/stores/",
        "entry/src/main/ets/fixtures/",
        "entry/src/main/ets/support/"
      ],
      "input_specs": [
        "output/ios-analyze/specs/modules.json",
        "output/ios-analyze/specs/functions.json",
        "output/ios-analyze/specs/features.json",
        "output/platform-adaptation/capability-coverage.json",
        "output/platform-adaptation/implementation-guidance.json"
      ],
      "tasks": [
        {
          "id": "task.models.news",
          "description": "创建新闻领域模型：NewsCategory, NewsSource, NewsArticle, SentimentResult, ExtractedEntity, StoryCluster, WatchLaterItem, KeywordAlert, CustomRSSFeed, WeatherData, UserPreference",
          "target_file": "entry/src/main/ets/models/news/",
          "ios_sources": [
            "NewsMobile/NewsMobile/Models/NewsModels.swift"
          ],
          "depends_on": []
        },
        {
          "id": "task.models.settings",
          "description": "创建设置模型：NewsMobileSettings 包含所有用户偏好字段",
          "target_file": "entry/src/main/ets/models/settings/NewsMobileSettings.ets",
          "ios_sources": [
            "NewsMobile/NewsMobile/Models/NewsModels.swift"
          ],
          "depends_on": ["task.models.news"]
        },
        {
          "id": "task.support.util",
          "description": "创建工具类：DateUtils 日期格式化、TextUtils HTML清理和文本高亮、Constants 常量定义",
          "target_file": "entry/src/main/ets/support/",
          "ios_sources": [],
          "depends_on": []
        },
        {
          "id": "task.services.http_client",
          "description": "创建 HttpClient 封装 @ohos.net.http，实现 GET/POST/通用请求、超时和错误处理",
          "target_file": "entry/src/main/ets/services/news/HttpClient.ets",
          "ios_sources": [
            "NewsMobile/NewsMobile/Services/NewsAggregator.swift"
          ],
          "depends_on": ["task.support.util"]
        },
        {
          "id": "task.services.rss_parser",
          "description": "创建 RssParser 解析 RSS 2.0 和 Atom 格式，处理日期解析和 HTML 清理",
          "target_file": "entry/src/main/ets/services/rss/RssParser.ets",
          "ios_sources": [
            "NewsMobile/NewsMobile/Services/RSSParser.swift"
          ],
          "depends_on": ["task.models.news", "task.services.http_client"]
        },
        {
