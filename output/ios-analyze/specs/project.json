{
  "project_name": "NewsMobile",
  "root": "NewsMobile",
  "summary": "Native SwiftUI news reader with RSS aggregation, on-device ML analysis, personalization, watch-later storage, notification alerts, weather/local news, custom feeds, audio briefings, and WidgetKit extension.",
  "targets": [
    {
      "name": "NewsMobile",
      "type": "iOS app",
      "bundle_id": "com.jordankoch.NewsMobile",
      "deployment_target": "18.0",
      "entry_points": [
        "NewsMobile/NewsMobile/NewsMobileApp.swift",
        "NewsMobile/NewsMobile/ContentView.swift"
      ]
    },
    {
      "name": "NewsMobileWidget",
      "type": "WidgetKit extension",
      "bundle_id": "com.jordankoch.NewsMobile.widget",
      "deployment_target": "17.0",
      "entry_points": [
        "NewsMobile/NewsMobileWidget/NewsMobileWidget.swift"
      ]
    },
    {
      "name": "NewsMobileTests",
      "type": "XCTest",
      "bundle_id": "com.jordankoch.NewsMobile.Tests"
    }
  ],
  "schemes": [
    "NewsMobile"
  ],
  "dependencies": [
    "SwiftUI",
    "Foundation",
    "NaturalLanguage",
    "BackgroundTasks",
    "Network",
    "AVFoundation",
    "CoreLocation",
    "WebKit",
    "WidgetKit",
    "UserNotifications"
  ],
  "entitlements": [
    "aps-environment",
    "com.apple.developer.icloud-container-identifiers",
    "com.apple.developer.icloud-services",
    "com.apple.developer.ubiquity-kvstore-identifier",
    "com.apple.security.application-groups"
  ],
  "asset_catalogs": [
    "NewsMobile/NewsMobile/Resources/Assets.xcassets",
    "NewsMobile/NewsMobileWidget/Assets.xcassets"
  ],
  "scan_outputs": [
    "output/ios-analyze/scan/project.scan.json",
    "output/ios-analyze/scan/source_index.json",
    "output/ios-analyze/scan/module_hints.json",
    "output/ios-analyze/scan/ui_hints.json",
    "output/ios-analyze/scan/capability_hints.json"
  ],
  "build_notes": [
    "README states zero external dependencies and Apple first-party frameworks only.",
    "The app already includes a -uiSnapshotMode / -snapshotScreen path in ContentView.swift for deterministic sample data screenshots."
  ]
}
