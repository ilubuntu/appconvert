      ],
      "fallback": "用数组缓存 + 定时轮询"
    },
    {
      "id": "concurrency.timer_publish",
      "category": "concurrency",
      "ios": {
        "frameworks": [
          "SwiftUI",
          "Foundation"
        ],
        "apis": [
          "Timer.publish",
          "Timer.scheduledTimer",
          "CADisplayLink",
          "Timer.connect"
        ],
        "entitlements": [],
        "permissions": []
      },
      "harmony": {
        "kit": "ArkTS",
        "api_area": "setInterval / setTimeout",
        "target_boundary": "components/*, pages/*"
      },
      "strategy": "native_equivalent",
      "permission": {
        "required": false,
        "notes": ""
      },
      "manifest": {
        "required": false,
        "notes": ""
      },
      "risk_level": "low",
      "implementation_notes": [
        "Timer.publish(every: 1, on: .main, in: .common).autoconnect() → setInterval(() => {...}, 1000)",
        "SwiftUI .onReceive(timer) → 直接在 setInterval 回调中更新状态",
        "concurrency_detail 中的 interval 值必须保留（ms 单位）",
        "组件销毁时必须 clearInterval 防止泄漏"
      ],
      "fallback": "无。"
    },
    {
      "id": "concurrency.dispatch_async",
      "category": "concurrency",
      "ios": {
        "frameworks": [
          "Foundation"
        ],
        "apis": [
          "DispatchQueue.main.asyncAfter",
          "DispatchQueue.main.async"
        ],
        "entitlements": [],
