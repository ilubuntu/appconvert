      "harmony": {
        "kit": "ArkTS",
        "api_area": "setTimeout / Promise.resolve().then()",
        "target_boundary": "pages/*, components/*"
      },
      "strategy": "native_equivalent",
      "permission": {
        "required": false,
        "notes": ""
      },
      "manifest": {
        "required": false,
        "notes": ""
      },
      "risk_level": "low",
      "implementation_notes": [
        "DispatchQueue.main.asyncAfter(deadline: .now() + 5) → setTimeout(() => {...}, 5000)",
        "DispatchQueue.main.async { } → setTimeout(() => {...}, 0) 或 Promise.resolve().then(() => {...})",
        "concurrency_detail 中的 delay 值必须保留（转为 ms）"
      ],
      "fallback": "无。"
    }
