      "harmony": {
        "kit": "ArkTS",
        "api_area": "async/await + Promise",
        "target_boundary": "services/*"
      },
      "strategy": "native_equivalent",
      "permission": {
        "required": false,
        "notes": ""
      },
      "manifest": {
        "required": false,
        "notes": ""
      },
      "risk_level": "low",
      "implementation_notes": [
        "Swift async func → ArkTS async func，保持 async/await 语法",
        "Swift Task { ... } → ArkTS Promise 或直接 async 调用"
      ],
      "fallback": "无。"
    },
    {
      "id": "concurrency.combine",
      "category": "concurrency",
      "ios": {
        "frameworks": [
          "Combine",
          "SwiftUI"
        ],
        "apis": [
          "@Published",
          "Publisher",
          "sink",
          "assign",
          "onReceive"
        ],
        "entitlements": [],
        "permissions": []
      },
      "harmony": {
        "kit": "ArkUI V2 State",
        "api_area": "@ObservedV2 + @Trace + @Monitor",
        "target_boundary": "stores/*, pages/*"
      },
      "strategy": "api_replacement",
      "permission": {
        "required": false,
        "notes": ""
      },
      "manifest": {
        "required": false,
        "notes": ""
      },
      "risk_level": "medium",
      "implementation_notes": [
        "iOS @Published var x → @Trace x: Type",
        "iOS sink/assign 订阅 → @Monitor 监听变化",
        "SwiftUI .onReceive(Just(value)) → @Monitor 或 onChange"
      ],
      "fallback": "用 setTimeout 轮询模拟（不推荐）"
    },
    {
      "id": "concurrency.gcd",
      "category": "concurrency",
      "ios": {
        "frameworks": [
          "Foundation"
        ],
        "apis": [
          "DispatchQueue.global().async",
          "DispatchSemaphore",
          "DispatchGroup"
        ],
        "entitlements": [],
